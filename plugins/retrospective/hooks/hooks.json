{
  "description": "retrospective plugin hooks: drop a marker when exiting plan mode; nag at SessionStart about outstanding retrospectives.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/exit-plan-mode-marker.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-retro-nag.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
