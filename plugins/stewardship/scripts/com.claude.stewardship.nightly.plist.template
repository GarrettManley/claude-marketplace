<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.claude.stewardship.nightly.plist.template
  macOS LaunchAgent for the stewardship nightly steward.

  Install:
    1. Set PLUGIN_PATH to the absolute path of the stewardship plugin directory
       (the directory that contains scripts/drift_check.py).
    2. Set LOG_DIR to an absolute writable log directory, e.g.
         $HOME/Library/Logs/stewardship-plugin
       Create the directory first: mkdir -p "$LOG_DIR"
    3. Substitute all PLUGIN_PATH and LOG_DIR placeholders in this file, then copy
       it into the user LaunchAgents directory and load it:

         cp com.claude.stewardship.nightly.plist \
            ~/Library/LaunchAgents/com.claude.stewardship.nightly.plist
         launchctl load -w \
            ~/Library/LaunchAgents/com.claude.stewardship.nightly.plist

  Verify (check for errors after the next 03:00 run):
    launchctl list | grep stewardship
    cat LOG_DIR/nightly.log

  Uninstall:
    launchctl unload -w \
       ~/Library/LaunchAgents/com.claude.stewardship.nightly.plist
    rm ~/Library/LaunchAgents/com.claude.stewardship.nightly.plist

  Notes:
  - StartCalendarInterval fires at 03:00 local time daily.
  - If the machine is asleep at 03:00 the job is skipped; it does not run on
    wake. Add a second StartCalendarInterval entry or use a wrapper that
    checks whether today's log already exists if you need catch-up behaviour.
  - StandardOutPath and StandardErrorPath capture both stdout and stderr.
  - To enable archival mode for auto_memory_housekeep (the "apply" flag), create
    a small shell wrapper script that calls both Python scripts and point
    ProgramArguments at it.
  - The RunAtLoad key is set to false; the agent will only fire on the
    calendar trigger, not every time the agent is loaded.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude.stewardship.nightly</string>

    <!--
      ProgramArguments: run a shell that sequences drift_check then
      auto_memory_housekeep so both always execute and both log to the
      same file. Replace PLUGIN_PATH and LOG_DIR before loading.
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>
            python3 "PLUGIN_PATH/scripts/drift_check.py" &amp;&amp;
            python3 "PLUGIN_PATH/scripts/auto_memory_housekeep.py" &amp;&amp;
            python3 "PLUGIN_PATH/scripts/horizon_scan_schedule.py"
        </string>
    </array>

    <!-- Fire daily at 03:00 local time. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Capture stdout and stderr to the log file. -->
    <key>StandardOutPath</key>
    <string>LOG_DIR/nightly.log</string>
    <key>StandardErrorPath</key>
    <string>LOG_DIR/nightly.log</string>

    <!-- Do not run immediately on load; wait for the calendar trigger. -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Keep the job enabled across reboots. -->
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
