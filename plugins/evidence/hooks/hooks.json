{
  "description": "evidence plugin hooks: secret-scan + scope-binding PreToolUse defense-in-depth.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project \"${CLAUDE_PLUGIN_ROOT}/hooks/secret_scan.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebFetch|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project \"${CLAUDE_PLUGIN_ROOT}/hooks/scope_bind.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
